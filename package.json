{
  "name": "vscode-today-is-done",
  "displayName": "Today's Done",
  "publisher": "restard",
  "description": "Automatically track work time per project",
  "version": "0.1.0",
  "engines": {
    "vscode": "^1.80.0"
  },
  "icon": "icon.png",
  "repository": {
    "type": "git",
    "url": "https://github.com/restard/today-is-done"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "timetracker.showPanel",
        "title": "Today's Done: Open Panel"
      },
      {
        "command": "timetracker.copyToday",
        "title": "Today's Done: Copy Today's Summary"
      },
      {
        "command": "timetracker.copyDate",
        "title": "Today's Done: Copy Summary for a Date..."
      },
      {
        "command": "timetracker.showLog",
        "title": "Today's Done: Show Activity Log"
      },
      {
        "command": "timetracker.reset",
        "title": "Today's Done: Reset Today's Data"
      }
    ],
    "configuration": {
      "title": "Today's Done",
      "properties": {
        "timetracker.timeoutMinutes": {
          "type": "number",
          "default": 2,
          "description": "Idle timeout in minutes"
        },
        "timetracker.outputFormat": {
          "type": "string",
          "default": "markdown",
          "enum": [
            "markdown",
            "plain"
          ],
          "description": "Output format (markdown / plain)"
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "pnpm build",
    "build": "esbuild src/extension.ts --bundle --outfile=dist/extension.js --external:vscode --format=cjs --platform=node --minify",
    "watch": "esbuild src/extension.ts --bundle --outfile=dist/extension.js --external:vscode --format=cjs --platform=node --watch",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "package": "NODE_NO_WARNINGS=1 vsce package"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@types/vscode": "^1.80.0",
    "esbuild": "^0.25.0",
    "typescript": "^6.0.0",
    "@vscode/vsce": "^3.0.0"
  },
  "packageManager": "pnpm@10.28.2+sha512.41872f037ad22f7348e3b1debbaf7e867cfd448f2726d9cf74c08f19507c31d2c8e7a11525b983febc2df640b5438dee6023ebb1f84ed43cc2d654d2bc326264"
}
